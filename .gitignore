# ============================================
# Git Ignore Configuration for Email Automation
# ============================================

# Secret configuration containing passwords/API keys
.env
*.env

# Python Bytecode and Cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# Project Logs (ignore log files, keep directory structure)
logs/*.log
!logs/.gitkeep

# Operating System Files
.DS_Store
Thumbs.db
desktop.ini

# IDE & Editor Settings
.vscode/
.idea/
*.swp
*.swo
